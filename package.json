{
  "name": "lrbridge",
  "version": "0.5.2",
  "description": "Local HTTP bridge and Web Controller for controlling Adobe Lightroom Classic from Bitfocus Companion, Stream Deck, Loupedeck, PowerShell, curl, scripts, and other HTTP-capable tools.",
  "main": "app/main.js",
  "scripts": {
    "test": "npm run test:contract && npm run test:lifecycle && npm run test:input && npm run test:queue && npm run test:diagnostics && npm run test:transport && npm run test:http-transport && npm run test:controller-proxy && npm run test:controller-http && npm run test:controller-shutdown && npm run test:lua-polling && npm run test:lua-selection",
    "start": "electron app/main.js",
    "smoke": "node tests/http-smoke.js",
    "test:contract": "node tests/contract-baseline.js",
    "test:lifecycle": "node tests/lifecycle.js",
    "test:input": "node tests/input-validation.js",
    "test:queue": "node tests/queue-resilience.js",
    "test:diagnostics": "node tests/queue-diagnostics.js",
    "test:transport": "node tests/transport-limits.js",
    "test:http-transport": "node tests/http-transport-limits.js",
    "test:controller-proxy": "node tests/controller-proxy.js",
    "test:controller-http": "node tests/controller-http-limits.js",
    "test:controller-shutdown": "node tests/controller-shutdown.js",
    "test:lua-polling": "node tests/lua-polling-resilience.js",
    "test:lua-selection": "node tests/lua-selection-dispatch.js",
    "test:smoke-live": "node tests/http-smoke.js",
    "app": "electron app/main.js",
    "server": "node bridge.js",
    "generate:cheatsheet": "node tools/generate-companion-cheatsheet.js",
    "pack:win": "electron-builder --win --x64 --dir",
    "dist:win": "npm run pack:win && powershell -NoProfile -ExecutionPolicy Bypass -File tools/make-portable-zip.ps1"
  },
  "keywords": [
    "lightroom",
    "lightroom-classic",
    "adobe-lightroom",
    "lightroom-controller",
    "lightroom-http-api",
    "lightroom-bridge",
    "bitfocus-companion",
    "generic-http-requests",
    "stream-deck",
    "streamdeck",
    "loupedeck",
    "control-surface",
    "photo-editing",
    "electron",
    "nodejs",
    "lua"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
